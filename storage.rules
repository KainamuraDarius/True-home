rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Verification documents - organized by user
    match /verification_documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Property images - public read with CORS support
    match /properties/{fileName} {
      allow read: if true;  // Public read
      allow write: if request.auth != null;
    }
    
    // Project images - public read with CORS support
    match /projects/{fileName} {
      allow read: if true;  // Public read
      allow write: if request.auth != null;
    }
    
    // Profile pictures - public read with CORS support  
    match /profiles/{fileName} {
      allow read: if true;  // Public read
      allow write: if request.auth != null;
    }
    
    // Company icons - public read with CORS support
    match /company_icons/{fileName} {
      allow read: if true;  // Public read
      allow write: if request.auth != null;
    }
    
    // General images folder - authenticated users only
    match /images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Fallback - deny by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
