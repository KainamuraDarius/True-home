rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Give admins full access to all documents and collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        ('admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRole == 'admin');
    }

    // Allow only safe public +1 counter increments on advertised projects
    function isSafeProjectCounterIncrement() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();

      let viewCountValid = (
        (!('viewCount' in resource.data) && request.resource.data.viewCount == 1) ||
        (('viewCount' in resource.data) && request.resource.data.viewCount == resource.data.viewCount + 1)
      );

      let clickCountValid = (
        (!('clickCount' in resource.data) && request.resource.data.clickCount == 1) ||
        (('clickCount' in resource.data) && request.resource.data.clickCount == resource.data.clickCount + 1)
      );

      return resource.data.isApproved == true && (
        (changedKeys.hasOnly(['viewCount']) && viewCountValid) ||
        (changedKeys.hasOnly(['clickCount']) && clickCountValid) ||
        (changedKeys.hasOnly(['viewCount', 'clickCount']) && viewCountValid && clickCountValid)
      );
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // Allow user to delete their own account or any admin to delete any user
      allow delete: if isOwner(userId) || isAdmin();
      // Allow user to update their own profile OR allow rating service to update agent stats
      // OR allow updating verification status fields OR allow admins to update verification
      // TEMPORARY: Allow users to update their own roles field to set up admin
      allow update: if isOwner(userId) || 
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['averageRating', 'totalRatings', 'totalReviews']
        )) ||
        (isSignedIn() && request.auth.uid == userId && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['verificationStatus', 'verificationRequestedAt']
        )) ||
        (isSignedIn() && request.auth.uid == userId && 
         request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['roles', 'role']
        )) ||
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['isVerified', 'verifiedAt', 'verificationStatus', 'unverifiedAt']
        ));
    }
    
    // Properties collection
    match /properties/{propertyId} {
      // Public users can browse approved active properties.
      // Owners can still read their own drafts, and admins can read everything.
      allow read: if (
        resource.data.status == 'approved'
      ) || (
        isSignedIn() && (
          resource.data.ownerId == request.auth.uid ||
          isAdmin()
        )
      );
      // Only property owner can create
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Owner can update/delete their own properties, admins can update any property
      // Also allow anyone to update room availability (roomTypes array) or view count
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        isAdmin() ||
        // Allow updating roomTypes and updatedAt fields for availability tracking
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roomTypes', 'updatedAt']) ||
        // Allow anyone authenticated to update view count
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
      );
      // Owner can delete their own properties, admins can delete any property
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }
    
    // Advertised Projects collection (for Browse New Projects section)
    match /advertised_projects/{projectId} {
      // Public users can browse approved projects.
      // Owners can still read their own submissions, and admins can read everything.
      allow read: if (
        (resource.data.isApproved == true) ||
        (isSignedIn() && resource.data.developerId == request.auth.uid) ||
        (isAdmin())
      );
      // Only project owner can write (except view/click counts)
      allow create: if isSignedIn() && request.resource.data.developerId == request.auth.uid;
      // Owner/admin can update full docs. Public can only increment counters safely by +1.
      allow update: if (
        (isSignedIn() && resource.data.developerId == request.auth.uid) ||
        isAdmin() ||
        isSafeProjectCounterIncrement()
      );
      // Owner can delete their own projects, admins can delete any project
      allow delete: if isSignedIn() && (resource.data.developerId == request.auth.uid || isAdmin());
    }
    
    // Bookmarks collection
    match /bookmarks/{bookmarkId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    // Reservations collection
    match /reservations/{reservationId} {
      // Students can read their own reservations, and admins can read all.
      allow read: if isSignedIn() && (
        resource.data.studentUserId == request.auth.uid ||
        isAdmin()
      );
      // Reservation records must belong to the authenticated student creating them.
      allow create: if isSignedIn() &&
        request.resource.data.studentUserId == request.auth.uid;
      // Only reservation creator or admin can update
      allow update: if isSignedIn() && (
        (resource.data.studentUserId != null && resource.data.studentUserId == request.auth.uid) ||
        isAdmin()
      );
      // Students can delete their own pending reservations (effectively cancelling); admins can delete any
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.studentUserId == request.auth.uid && resource.data.status == 'pending');
    }

    // Custodian booking follow-up records
    match /custodian_booking_notifications/{notificationId} {
      // Students can create follow-up records for their own reservations.
      allow create: if isSignedIn() &&
        request.resource.data.studentUserId == request.auth.uid;
      // Admins can review these records for support and reporting.
      allow read, update, delete: if isAdmin();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can update their own notifications (mark as read)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Anyone authenticated can create notifications (for system notifications)
      allow create: if isSignedIn();
      // Users can delete their own notifications
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // Messages/Chats collection
    match /chats/{chatId} {
      // Users can read chats they're part of
      allow read: if isSignedIn() && 
        (request.auth.uid in resource.data.participants);
      // Users can create chats they're part of
      allow create: if isSignedIn() && 
        (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && 
        (request.auth.uid in resource.data.participants);
        
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }
    
    // Search history
    match /search_history/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Admin-only collections
    match /admin/{document=**} {
      allow read, write: if isSignedIn() && 
        ('admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles);
    }
    
    // Property reviews
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // Email verification codes
    match /verification_codes/{userId} {
      // Users can read and write their own verification codes
      allow read, write: if isOwner(userId);
    }
    
    // Agent ratings collection
    match /agent_ratings/{ratingId} {
      // Anyone can read ratings
      allow read: if isSignedIn();
      // Only the customer who created the rating can write/update/delete it
      allow create: if isSignedIn() && 
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.agentId != request.auth.uid; // Can't rate yourself
      allow update, delete: if isSignedIn() && 
        resource.data.customerId == request.auth.uid;
    }
    
    // Verification requests collection
    match /verification_requests/{userId} {
      // Agents can create and read their own verification request
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Admins can read and update all requests (check roles array)
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }
    
    // App settings collection (maintenance mode, etc.)
    match /app_settings/{document} {
      // Anyone can read app settings (to check maintenance mode)
      allow read: if true;
      // Admins can write - simplified check since only admin panel accesses this
      allow write: if isSignedIn() && (
        isAdmin() ||
        // Fallback: check custom claims or email
        request.auth.token.admin == true ||
        request.auth.token.email == 'truehome376@gmail.com'
      );
    }
    
    // App config collection (maintenance mode - used by MaintenanceService)
    match /app_config/{document} {
      // Anyone can read app config (to check maintenance mode)
      allow read: if true;
      // Admins can write
      allow write: if isSignedIn() && (
        isAdmin() ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'truehome376@gmail.com'
      );
    }
    
    // Audit logs collection
    match /audit_logs/{logId} {
      // Admins can read and create audit logs
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    
    // Scheduled notifications collection
    match /scheduled_notifications/{notificationId} {
      // Admins can manage scheduled notifications
      allow read, write: if isSignedIn();
    }
  }
}
